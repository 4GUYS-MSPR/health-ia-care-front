# Logging Configuration
# Available levels: ALL, FINEST, FINER, FINE, CONFIG, INFO, WARNING, SEVERE, SHOUT, OFF
LOG_ROOT_LEVEL=INFO
LOG_USE_UTC=true
LOG_HIERARCHICAL=true
# Per-feature log levels. Format: "FeatureName:LEVEL;AnotherFeature:LEVEL"
# Example: "Auth:FINE;Auth.Data:FINER;Core:INFO;Auth.Domain.SignInUsecase:FINEST"
LOG_FEATURE_LEVELS=

# Console Handler
LOG_CONSOLE_ENABLED=true

# Whether to include color in console log output
LOG_CONSOLE_USE_COLOR=false

# Output Options
# Whether to include error objects in log output
LOG_SHOW_ERROR=true
# Whether to include stack traces in log output
LOG_SHOW_STACK_TRACE=true

# File Handler (ignored on web)
LOG_FILE_ENABLED=true
# Path relative to app documents directory
LOG_FILE_PATH=health_ia_care_app/logs/app.log
# Maximum size of a single log file in kilobytes (5MB default)
LOG_FILE_MAX_SIZE_KB=5120
# Maximum number of rotated log files to keep
LOG_FILE_MAX_COUNT=5
